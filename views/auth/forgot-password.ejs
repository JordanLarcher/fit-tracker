<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Tempo</title>
  <link rel="stylesheet" href="/css/tempo.css" />
  <style>
    .auth-card { max-width: 420px; margin: auto; }
    #forgot-response { margin-top: 16px; font-size: .9rem; }
    #forgot-response.success { color: #167a5b; }
    #forgot-response.error { color: #dc2626; }
  </style>
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand"><span class="brand__mark"></span> Tempo</div>
      <p class="eyebrow" style="margin-bottom:18px">Forgot password</p>
      <p style="color:var(--muted);font-size:.85rem;margin-bottom:20px">
        Enter your email and we'll send you a reset link.
      </p>
      <form id="form-forgot" novalidate>
        <div class="field">
          <label class="label" for="email">Email</label>
          <input class="input" type="email" id="email" placeholder="you@email.com" autocomplete="email" required />
        </div>
        <button type="submit" class="btn btn--dark" style="width:100%;justify-content:center" id="btn-submit">Send reset link</button>
      </form>
      <div id="forgot-response"></div>
      <p style="text-align:center;color:var(--muted);font-size:.85rem;margin:16px 0 0">
        <a href="/login">Back to sign in</a>
      </p>
    </div>
  </div>

  <div id="toast-container"></div>
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
  <script>
    document.getElementById('form-forgot').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      const response = document.getElementById('forgot-response');
      btn.disabled = true;
      btn.textContent = 'Sending...';
      response.className = '';
      response.textContent = '';
      try {
        const data = await api.post('/auth/forgot-password', {
          email: document.getElementById('email').value,
        });
        response.className = 'success';
        response.textContent = data.message;
        document.getElementById('email').value = '';
      } catch (err) {
        response.className = 'error';
        response.textContent = err.message || 'Something went wrong.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send reset link';
      }
    });
  </script>
</body>
</html>
