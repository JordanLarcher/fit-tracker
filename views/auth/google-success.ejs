<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Tempo</title>
</head>
<body>
  <p style="font-family:sans-serif;text-align:center;padding:48px;color:#9aa1a9;">Signing in with Google…</p>
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const token = params.get('token');
      if (token) {
        // Store the token first so api.get() below sends it as a Bearer header.
        localStorage.setItem('ft_token', token);
        api.get('/auth/me')
          .then((data) => {
            window.ftAuth.saveSession(token, data.user);
            window.location.href = '/dashboard';
          })
          .catch(() => {
            localStorage.removeItem('ft_token');
            window.location.href = '/login';
          });
      } else {
        window.location.href = '/login';
      }
    })();
  </script>
</body>
</html>
