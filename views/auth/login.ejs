<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Tempo</title>
  <link rel="stylesheet" href="/css/tempo.css" />
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand"><span class="brand__mark"></span> Tempo</div>

      <!-- Login -->
      <form id="form-login" novalidate>
        <p class="eyebrow" style="margin-bottom:18px">Sign in</p>
        <div class="field">
          <label class="label" for="email">Email</label>
          <input class="input" type="email" id="email" placeholder="you@email.com" autocomplete="email" required />
        </div>
        <div class="field">
          <label class="label" for="password">Password</label>
          <input class="input" type="password" id="password" placeholder="••••••••" autocomplete="current-password" required />
        </div>
        <button type="submit" class="btn btn--dark" style="width:100%;justify-content:center" id="btn-login-submit">Sign in</button>
        <p style="text-align:center;color:var(--muted);font-size:.85rem;margin:16px 0 0">
          Don't have an account? <a href="#" id="toggle-register">Create one</a>
        </p>
      </form>

      <!-- Register -->
      <form id="form-register" novalidate style="display:none">
        <p class="eyebrow" style="margin-bottom:18px">Create account</p>
        <div class="field">
          <label class="label" for="reg-name">Name</label>
          <input class="input" type="text" id="reg-name" placeholder="Jordan Larcher" required />
        </div>
        <div class="field">
          <label class="label" for="reg-email">Email</label>
          <input class="input" type="email" id="reg-email" placeholder="you@email.com" required />
        </div>
        <div class="field">
          <label class="label" for="reg-password">Password</label>
          <input class="input" type="password" id="reg-password" placeholder="Min. 8 characters" required />
        </div>
        <button type="submit" class="btn btn--dark" style="width:100%;justify-content:center">Create account</button>
        <p style="text-align:center;color:var(--muted);font-size:.85rem;margin:16px 0 0">
          Already have an account? <a href="#" id="toggle-login">Sign in</a>
        </p>
      </form>
    </div>
  </div>

  <div id="toast-container"></div>
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script>
    const fL = document.getElementById('form-login');
    const fR = document.getElementById('form-register');
    document.getElementById('toggle-register').addEventListener('click', (e) => { e.preventDefault(); fL.style.display = 'none'; fR.style.display = 'block'; });
    document.getElementById('toggle-login').addEventListener('click', (e) => { e.preventDefault(); fR.style.display = 'none'; fL.style.display = 'block'; });
  </script>
</body>
</html>
