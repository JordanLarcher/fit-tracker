<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Tempo</title>
  <link rel="stylesheet" href="/css/tempo.css" />
  <style>
    .auth-card { max-width: 420px; margin: auto; }
    #reset-response { margin-top: 16px; font-size: .9rem; }
    #reset-response.success { color: #167a5b; }
    #reset-response.error { color: #dc2626; }
  </style>
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand"><span class="brand__mark"></span> Tempo</div>
      <p class="eyebrow" style="margin-bottom:18px">Set new password</p>
      <form id="form-reset" novalidate>
        <div class="field">
          <label class="label" for="password">New password</label>
          <input class="input" type="password" id="password" placeholder="Min. 8 characters" autocomplete="new-password" required minlength="8" />
        </div>
        <button type="submit" class="btn btn--dark" style="width:100%;justify-content:center" id="btn-submit">Reset password</button>
      </form>
      <div id="reset-response"></div>
    </div>
  </div>

  <div id="toast-container"></div>
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script>
    document.getElementById('form-reset').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      const response = document.getElementById('reset-response');
      btn.disabled = true;
      btn.textContent = 'Resetting...';
      response.className = '';
      response.textContent = '';
      try {
        const token = '<%= token %>';
        const data = await api.post('/auth/reset-password/' + token, {
          password: document.getElementById('password').value,
        });
        window.ftAuth.saveSession(data.token, data.user);
        response.className = 'success';
        response.textContent = 'Password reset! Redirecting...';
        setTimeout(() => (window.location.href = '/dashboard'), 1200);
      } catch (err) {
        response.className = 'error';
        response.textContent = err.message || 'Token invalid or expired.';
        btn.disabled = false;
        btn.textContent = 'Reset password';
      }
    });
  </script>
</body>
</html>
