<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Tempo</title>
  <link rel="stylesheet" href="/css/tempo.css" />
  <!-- Shared utilities – must load before page-specific scripts in content -->
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
</head>
<body>
  <div class="app-shell">
    <%- include('../partials/nav', { active: typeof active !== 'undefined' ? active : '' }) %>

    <div class="main">
      <header class="topbar">
        <input class="topbar__search" type="search" placeholder="Search…" id="topbar-search" />
        <div class="topbar__avatar" title="Perfil"></div>
      </header>

      <main class="content">
        <%- body %>
      </main>
    </div>
  </div>

  <div id="toast-container"></div>

  <!-- Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

  <!-- Auth – must run after DOM is ready because it queries form elements -->
  <script src="/js/auth.js"></script>
</body>
</html>
