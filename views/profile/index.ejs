<div class="page-head">
  <p class="eyebrow">05 · Profile</p>
  <button class="btn btn--ghost" id="btn-logout-2">Log out</button>
</div>

<div class="card" style="max-width:520px">
  <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px">
    <span class="topbar__avatar"></span>
    <div>
      <p class="card-title" id="pf-name">—</p>
      <p class="card-sub" id="pf-email">—</p>
    </div>
  </div>
  <div class="grid grid--2">
    <div><p class="stat-label">Streak</p><div class="stat-num" id="pf-streak">0</div></div>
    <div><p class="stat-label">Role</p><div class="stat-num" id="pf-role" style="font-size:1.2rem">user</div></div>
  </div>
</div>

<script>
(async function () {
  try {
    const { user } = await api.get('/auth/me');
    document.getElementById('pf-name').textContent = user.name;
    document.getElementById('pf-email').textContent = user.email;
    document.getElementById('pf-streak').textContent = user.streak || 0;
    document.getElementById('pf-role').textContent = user.role || 'user';
  } catch (err) { showToast(err.message, 'error'); }
  document.getElementById('btn-logout-2').addEventListener('click', () => {
    window.ftAuth.clearSession();
    window.location.href = '/';
  });
})();
</script>
