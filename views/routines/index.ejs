<div class="page-head">
  <p class="eyebrow">03 · Routine Builder</p>
  <div style="display:flex;align-items:center;gap:16px">
    <label class="switch"><input type="checkbox" id="rt-public" /> Public</label>
    <button class="btn btn--dark" id="rt-save">Save routine</button>
  </div>
</div>

<div class="card" style="margin-bottom:20px">
  <input class="input input--lg" id="rt-name" placeholder="routine name" />
  <input type="hidden" id="rt-editing" value="" />
  <p class="subtle" style="margin:16px 0 8px">tags (for the public library)</p>
  <div class="chips" id="rt-tags" style="margin:0">
    <button type="button" class="chip" data-tag="fuerza">Strength</button>
    <button type="button" class="chip" data-tag="hipertrofia">Hypertrophy</button>
    <button type="button" class="chip" data-tag="full-body">Full-body</button>
    <button type="button" class="chip" data-tag="principiante">Beginner</button>
  </div>
</div>

<div class="builder">
  <!-- Catalog -->
  <div class="card builder-col">
    <p class="stat-label">Catalog</p>
    <div style="display:flex;gap:10px;align-items:center;margin-bottom:8px">
      <input class="input" id="rt-search" placeholder="search exercise…" />
    </div>
    <div id="rt-catalog"><p class="card-sub">Loading…</p></div>
  </div>

  <!-- Routine -->
  <div class="card builder-col">
    <p class="stat-label">Routine · <span id="rt-count">0</span> exercises</p>
    <div id="rt-selected"><p class="empty">Add exercises from the catalog →</p></div>
  </div>
</div>

<!-- My routines -->
<section style="margin-top:32px">
  <p class="eyebrow" style="margin-bottom:16px">My routines</p>
  <div class="grid grid--3" id="rt-mine"><p class="card-sub">Loading…</p></div>
</section>

<script src="/js/routines.js"></script>
